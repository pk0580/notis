APP_NAME="Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notifications
DB_USERNAME=postgres
DB_PASSWORD=password

CACHE_STORE=redis
CACHE_PREFIX=
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Notification settings (R14, R18)
NOTIFICATIONS_BATCH_MAX=5000
NOTIFICATIONS_INSERT_CHUNK=2000
NOTIFICATIONS_RETRY_BACKOFF_MS=1000,5000,25000,125000
NOTIFICATIONS_MAX_ATTEMPTS=5
NOTIFICATIONS_BODY_MAX_SMS=1000
NOTIFICATIONS_BODY_MAX_EMAIL=10000

# Secondary queue connection for SimulateDeliveryAckJob (A4)
QUEUE_DATABASE_CONNECTION=database
